# SQLite local por defecto si no defines DATABASE_URL:
# DATABASE_URL=sqlite:///./fitbit_tfm.db

# MySQL para despliegue/TFM.
# No subas credenciales reales a GitHub: usa .env local o variables de entorno del servidor.
DATABASE_URL=mysql+pymysql://USUARIO:PASSWORD_URL_ENCODED@HOST:3306/fitbit_tfm?charset=utf8mb4

# Dataset local de ejercicios:
DATASET_ROOT=exercises-dataset-main
DATASET_PATH=exercises-dataset-main/data/exercises.json
